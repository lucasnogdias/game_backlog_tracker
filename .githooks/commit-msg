#!/usr/bin/env bash
# Enforces commit messages to start with a task, bug, or chore prefix, e.g.:
#   TASK-0001: Set up git isolation and hooks
#   BUG-0007: Fix backlog sort order
#   CHORE: Bump application version
COMMIT_MSG_FILE="$1"
FIRST_LINE=$(head -n 1 "$COMMIT_MSG_FILE")
PATTERN="^((TASK|BUG)-[0-9]{4}|CHORE): .+"

if ! [[ "$FIRST_LINE" =~ $PATTERN ]]; then
  echo "Error: commit message must start with 'TASK-WXYZ: ', 'BUG-WXYZ: ', or 'CHORE: '." >&2
  echo "Got: \"$FIRST_LINE\"" >&2
  exit 1
fi
