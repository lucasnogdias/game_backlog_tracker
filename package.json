{
  "name": "game-backlog-tracker",
  "version": "1.0.1",
  "description": "A local-first desktop app for tracking game backlog and history.",
  "author": "lucasnogdias",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "electron:dev": "electron electron/main.cjs",
    "electron:clean": "node scripts/clean-electron.cjs",
    "electron:prepare": "node scripts/prepare-electron.cjs",
    "electron:rebuild": "electron-rebuild -f -w better-sqlite3",
    "electron:package": "node scripts/package-electron.cjs",
    "electron:build": "pnpm electron:build:mac",
    "electron:build:mac": "pnpm electron:package -- --mac dmg",
    "electron:build:win": "pnpm electron:package -- --win nsis",
    "electron:build:linux": "pnpm electron:package -- --linux AppImage deb",
    "electron:build:private": "INCLUDE_RAWG_KEY=true pnpm electron:build:mac",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-sqlite3": "^12.11.1",
    "fflate": "^0.8.3",
    "next": "15.5.20",
    "papaparse": "^5.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@eslint/eslintrc": "^3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "15.5.20",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "better-sqlite3"
    ]
  },
  "build": {
    "appId": "com.lucasnogdias.gamebacklogtracker",
    "productName": "Game Backlog Tracker",
    "asar": true,
    "npmRebuild": false,
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ],
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "next"
      },
      {
        "from": ".electron-build/server-modules",
        "to": "server-modules"
      },
      {
        "from": ".electron-build/desktop",
        "to": "desktop"
      },
      {
        "from": ".electron-build/default-settings.json",
        "to": "default-settings.json"
      },
      {
        "from": "prisma/migrations",
        "to": "prisma/migrations"
      }
    ],
    "mac": {
      "category": "public.app-category.entertainment",
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "maintainer": "lucasnogdias"
    }
  }
}
